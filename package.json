{
  "name": "neige",
  "version": "0.1.0",
  "description": "Neige is a long-lived multi-agent collaboration system built on OpenClaw",
  "license": "Apache-2.0",
  "author": "cloud-11",
  "homepage": "https://github.com/Cloud-11/neige#readme",
  "bugs": {
    "url": "https://github.com/Cloud-11/neige/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cloud-11/neige.git"
  },
  "type": "module",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "context-engine",
    "multi-agent",
    "memory",
    "neige"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "src/",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test",
    "neige:init": "node --import tsx scripts/init-neige.ts",
    "neige:switch": "node --import tsx scripts/switch-project.ts",
    "neige:health": "node --import tsx scripts/health-check.ts"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.8"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}

