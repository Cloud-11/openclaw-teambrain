{
  "name": "openclaw-teambrain",
  "version": "0.1.0",
  "description": "OpenClaw external team-brain context engine plugin for multi-agent and multi-project workflows",
  "license": "MIT",
  "author": "cloud-11",
  "homepage": "https://github.com/cloud-11/openclaw-teambrain#readme",
  "bugs": {
    "url": "https://github.com/cloud-11/openclaw-teambrain/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloud-11/openclaw-teambrain.git"
  },
  "type": "module",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "context-engine",
    "multi-agent",
    "memory",
    "teambrain"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "src/",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test",
    "teambrain:init": "node --import tsx scripts/init-teambrain.ts",
    "teambrain:switch": "node --import tsx scripts/switch-project.ts",
    "teambrain:health": "node --import tsx scripts/health-check.ts"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.8"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
